{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vitest"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "./eval/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
