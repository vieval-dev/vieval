{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "vieval": ["../../packages/vieval/src/index.ts"],
      "vieval/*": ["../../packages/vieval/src/*"]
    },
    "types": ["node", "vitest"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "./eval/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
